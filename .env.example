# Application
NODE_ENV=development
PORT=3000
HOST=localhost

# API Configuration
API_PREFIX=/api
API_VERSION=v1

# Security
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
LOG_FORMAT=dev

# Database (configure based on your choice)
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb
# MONGODB_URI=mongodb://localhost:27017/mydb
MONGODB_URI=
# JWT Authentication
JWT_ACCESS_SECRET=your-access-secret-key-min-32-chars-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars-change-in-production
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d
JWT_SECRET = qwerty

# Redis
REDIS_URL=redis://localhost:6379

# Redis (Alternative to REDIS_URL)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# OneSignal
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=

# Socket.io
SOCKET_PATH=/socket.io
SOCKET_CORS_ORIGIN=*

#Sendgrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_WELCOME_TEMPLATE_ID=