# Application
NODE_ENV=development
PORT=3000
HOST=localhost

# API Configuration
API_PREFIX=/api
API_VERSION=v1

# Security
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
LOG_FORMAT=dev

# Database (configure based on your choice)
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb
MONGODB_URI=mongodb://localhost:27018/mydb

# Redis
REDIS_URL=redis://localhost:6381

# JWT Authentication
JWT_ACCESS_SECRET=your-access-secret-key-min-32-chars-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
